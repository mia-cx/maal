{
	"name": "maal",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types && paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --silent && node scripts/patch-paraglide-types.mjs && wrangler types --check && vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types && paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --silent && node scripts/patch-paraglide-types.mjs && wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test:coverage": "vitest run --coverage",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"perf:load": "node scripts/perf/load-smoke.mjs",
		"duplicates:scan": "node scripts/find-semantic-duplicates.mjs",
		"boundaries:check": "node scripts/check-boundaries.mjs",
		"architecture:check": "pnpm boundaries:check && pnpm duplicates:scan",
		"gen": "wrangler types",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply maal-staging --local --env staging",
		"db:migrate:staging": "wrangler d1 migrations apply maal-staging --remote --env staging",
		"db:migrate:production": "wrangler d1 migrations apply maal-prod --remote --env production",
		"db:seed:smoke:local": "wrangler d1 execute maal-staging --local --env staging --file scripts/smoke/seed.sql",
		"db:seed:smoke:staging": "wrangler d1 execute maal-staging --remote --env staging --file scripts/smoke/seed.sql"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/noto-sans": "^5.2.10",
		"@fontsource-variable/nunito-sans": "^5.2.7",
		"@fontsource/lexend": "^5.2.11",
		"@inlang/paraglide-js": "^2.18.2",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^0.577.0",
		"@playwright/test": "^1.60.0",
		"@solar-icons/svelte": "^1.1.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.3",
		"@vitest/coverage-v8": "^4.1.8",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"formsnap": "^2.0.1",
		"globals": "^17.4.0",
		"layerchart": "2.0.0-next.48",
		"mdsvex": "^0.12.7",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"playwright": "^1.60.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.3.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0",
		"wrangler": "^4.81.0"
	},
	"dependencies": {
		"@fortawesome/free-brands-svg-icons": "^7.2.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@nanostores/persistent": "^1.3.4",
		"@workos-inc/node": "^10.2.0",
		"dexie": "^4.4.4",
		"effect": "4.0.0-beta.83",
		"nanostores": "^1.3.0",
		"stripe": "^22.2.0",
		"svelte-fa": "^4.0.4"
	}
}
